{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
            "System": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "DB_CONNECTION_STRING"
    },
    "Jwt": {
        "Key": "JWT_SECRET",
        "Issuer": "FileShareAPI",
        "Audience": "FileShareClient",
        "ExpiryMinutes": 60,
        "AccessTokenExpiryInMinutes": 15,
        "RefreshTokenExpiryInMinutes": 43200
    },
    "R2Storage": {
        "AccountId": "  ",
        "AccessKey": "R2_ACCESS_KEY",
        "SecretKey": "R2_SECRET_KEY",
        "BucketName": "vaultix",
        "Endpoint": "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
    },
    "Cors": {
        "AllowedOrigins": [
            "https://vaultix.vercel.app",
            "https://vaultix.deeppatel.tech"
        ]
    },
    "AuthCookie": {
        "HttpOnly": true,
        "Secure": true,
        "SameSite": "None",
        "Path": "/",
        "Domain": ".deeppatel.tech",
        "ExpiryDays": 7,
        "IsEssential": true
    }
}
